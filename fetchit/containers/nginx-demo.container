[Container]
# Demo version tags: registry.k8s.io/nginx-slim:0.8 (current), registry.k8s.io/nginx-slim:0.7 (rollback option)
Image=registry.k8s.io/nginx-slim:0.8
ContainerName=nginx-demo
PublishPort=8081:80
Volume=/var/www/nginx:/usr/share/nginx/html:Z

[Service]
Restart=always

[Install]
WantedBy=multi-user.target
